{
  "name": "@unlikeotherai/appreveal",
  "version": "0.7.0",
  "description": "CLI for discovering and querying AppReveal MCP servers on the local network",
  "type": "module",
  "bin": {
    "appreveal": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test test/**/*.test.ts",
    "start": "tsx src/index.ts"
  },
  "keywords": [
    "appreveal",
    "mcp",
    "cli",
    "mdns",
    "bonjour"
  ],
  "license": "MIT",
  "packageManager": "pnpm@10.22.0",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/UnlikeOtherAI/AppReveal.git",
    "directory": "CLI"
  },
  "homepage": "https://github.com/UnlikeOtherAI/AppReveal/tree/main/CLI",
  "bugs": {
    "url": "https://github.com/UnlikeOtherAI/AppReveal/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "bonjour-service": "^1.3.0",
    "commander": "^14.0.1"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
